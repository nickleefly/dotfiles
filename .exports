# Common Exports
export EDITOR=vim
export VISUAL="$EDITOR"
export MANPAGER="less -R"
export LANG=en_US.UTF-8
export LC_ALL=en_US.UTF-8

# PATH Management - Use a deduplicated approach
path_add() {
    if [ -d "$1" ] && [[ ":$PATH:" != *":$1:"* ]]; then
        export PATH="$1:$PATH"
    fi
}

path_add "$HOME/local/bin"
path_add "$HOME/bin"
path_add "/usr/local/bin"
path_add "/opt/homebrew/bin"
path_add "$HOME/.n/bin"
path_add "$HOME/npm-global/bin"
path_add "$ANDROID_HOME/tools"
path_add "$ANDROID_HOME/platform-tools"

# Mac specific adjustments
export COPYFILE_DISABLE=true
export NODE_REPL_HISTORY_FILE=~/.node-history
export histchars="!:#"
export GPG_TTY=$(tty)
